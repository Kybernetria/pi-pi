{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["extensions/**/*.ts", "protocol/**/*.ts", "scripts/**/*.ts"]
}
