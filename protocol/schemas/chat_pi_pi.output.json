{
  "type": "object",
  "required": ["status", "reply"],
  "additionalProperties": false,
  "properties": {
    "status": {
      "type": "string",
      "enum": ["clarification_needed", "completed", "unsupported"]
    },
    "reply": { "type": "string" },
    "questions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "missingInformation": {
      "type": "array",
      "items": { "type": "string" }
    },
    "assumptionsOffered": {
      "type": "array",
      "items": { "type": "string" }
    },
    "canProceedWithAssumptions": { "type": "boolean" },
    "reasons": {
      "type": "array",
      "items": { "type": "string" }
    },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "repoDir",
        "buildMode",
        "applied",
        "packages",
        "changedFiles",
        "validation",
        "verification",
        "assumptions",
        "summary"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["source_validated", "runtime_verified"]
        },
        "repoDir": { "type": "string" },
        "buildMode": {
          "type": "string",
          "enum": ["greenfield-single-node", "greenfield-pair", "brownfield-single-node"]
        },
        "applied": { "type": "boolean" },
        "packages": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["packageName", "nodeId", "packageDir", "changedFiles", "provides"],
            "properties": {
              "packageName": { "type": "string" },
              "nodeId": { "type": "string" },
              "packageDir": { "type": "string" },
              "changedFiles": {
                "type": "array",
                "items": { "type": "string" }
              },
              "provides": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "changedFiles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "validation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["pass", "validationMode", "packageCount"],
          "properties": {
            "pass": { "enum": [true] },
            "validationMode": {
              "type": "string",
              "enum": ["ast-assisted-source"]
            },
            "packageCount": { "type": "integer" }
          }
        },
        "verification": {
          "type": "object",
          "additionalProperties": false,
          "required": ["sdkDistribution", "sdkSourceOfTruth", "stages", "stagedRuntime"],
          "properties": {
            "sdkDistribution": {
              "type": "string",
              "enum": ["vendored-shim"]
            },
            "sdkSourceOfTruth": {
              "type": "string",
              "enum": ["vendor/pi-protocol-sdk.ts"]
            },
            "stages": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "sourceGenerated",
                "sourceValidated",
                "dependenciesResolved",
                "packageInstallable",
                "packageLoadable",
                "nodeRegistered",
                "publicProvideInvokable",
                "targetFilesApplied",
                "targetRuntimeVerified"
              ],
              "properties": {
                "sourceGenerated": { "enum": [true] },
                "sourceValidated": { "enum": [true] },
                "dependenciesResolved": { "enum": [true] },
                "packageInstallable": { "enum": [true] },
                "packageLoadable": { "enum": [true] },
                "nodeRegistered": { "enum": [true] },
                "publicProvideInvokable": { "enum": [true] },
                "targetFilesApplied": { "type": "boolean" },
                "targetRuntimeVerified": { "type": "boolean" }
              }
            },
            "stagedRuntime": {
              "type": "object",
              "additionalProperties": false,
              "required": ["packageCount", "registeredNodeIds", "invokedProvides"],
              "properties": {
                "packageCount": { "type": "integer" },
                "registeredNodeIds": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "invokedProvides": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            },
            "targetRuntime": {
              "type": "object",
              "additionalProperties": false,
              "required": ["packageCount", "registeredNodeIds", "invokedProvides"],
              "properties": {
                "packageCount": { "type": "integer" },
                "registeredNodeIds": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "invokedProvides": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          }
        },
        "assumptions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "summary": { "type": "string" }
      }
    }
  }
}
