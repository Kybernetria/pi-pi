{
  "protocolVersion": "0.2.0",
  "nodeId": "pi_pi",
  "packageId": "pi-pi",
  "version": "0.1.0",
  "purpose": "Protocol-invoked agent builder for pi-protocol compatible Pi packages/extensions.",
  "agents": {
    "protocol_builder": {
      "description": "Pi Protocol package builder agent.",
      "systemPrompt": {
        "text": "This agent's full builder prompt is supplied by protocol/agent-builder.ts so pi-pi can keep its protocol knowledge in code and tests. It builds exactly the requested Pi package/extension in the supplied targetDir using pi-protocol 0.2.0.",
        "mode": "append"
      }
    }
  },
  "provides": [
    {
      "name": "build_package",
      "description": "Invoke this protocol agent to build/adapt/repair the requested Pi package or extension in targetDir.",
      "inputSchema": {
        "type": "object",
        "required": ["request", "targetDir"],
        "properties": {
          "request": { "type": "string" },
          "targetDir": { "type": "string" }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": ["status", "summary"],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["completed", "clarification_needed", "unsupported", "failed"]
          },
          "summary": { "type": "string" },
          "targetDir": { "type": "string" },
          "filesWritten": { "type": "array", "items": { "type": "string" } },
          "nextSteps": { "type": "array", "items": { "type": "string" } },
          "diagnostics": { "type": "array", "items": { "type": "string" } }
        }
      },
      "execution": {
        "type": "agent",
        "agent": "protocol_builder"
      },
      "effects": ["file_read", "file_write"]
    }
  ]
}
