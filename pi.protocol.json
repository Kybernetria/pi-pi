{
  "protocolVersion": "0.2.0",
  "nodeId": "pi_pi",
  "packageId": "pi-pi",
  "version": "0.1.0",
  "purpose": "Build, adapt, and repair pi-protocol compatible Pi packages/extensions.",
  "provides": [
    {
      "name": "build_package",
      "description": "Build or repair a pi-protocol compatible package from a natural-language request.",
      "inputSchema": {
        "type": "object",
        "required": ["request"],
        "properties": {
          "request": { "type": "string" },
          "targetDir": { "type": "string" },
          "applyChanges": { "type": "boolean" },
          "mode": {
            "type": "string",
            "enum": ["new", "adapt", "repair", "explain"]
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": ["status", "summary"],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["completed", "clarification_needed", "unsupported", "failed"]
          },
          "summary": { "type": "string" },
          "targetDir": { "type": "string" },
          "filesWritten": {
            "type": "array",
            "items": { "type": "string" }
          },
          "nextSteps": {
            "type": "array",
            "items": { "type": "string" }
          },
          "diagnostics": {
            "type": "array",
            "items": { "type": "string" }
          },
          "plan": {
            "type": "array",
            "items": { "type": "string" }
          },
          "filePreviews": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "execution": {
        "type": "handler",
        "handler": "build_package"
      },
      "effects": ["file_read", "file_write"]
    },
    {
      "name": "chat",
      "description": "Chat-style alias for build_package. Use input.message or input.request.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "message": { "type": "string" },
          "request": { "type": "string" },
          "targetDir": { "type": "string" },
          "applyChanges": { "type": "boolean" },
          "mode": { "type": "string", "enum": ["new", "adapt", "repair", "explain"] }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": ["status", "summary"],
        "properties": {
          "status": { "type": "string" },
          "summary": { "type": "string" },
          "targetDir": { "type": "string" },
          "filesWritten": { "type": "array", "items": { "type": "string" } },
          "nextSteps": { "type": "array", "items": { "type": "string" } },
          "diagnostics": { "type": "array", "items": { "type": "string" } },
          "plan": { "type": "array", "items": { "type": "string" } },
          "filePreviews": { "type": "array", "items": { "type": "string" } }
        }
      },
      "execution": { "type": "handler", "handler": "chat" },
      "effects": ["file_read", "file_write"]
    }
  ]
}
